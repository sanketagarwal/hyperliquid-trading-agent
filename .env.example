# === Required ===
ANTHROPIC_API_KEY=your_anthropic_api_key_here   # From https://console.anthropic.com
HYPERLIQUID_PRIVATE_KEY=0x_your_private_key_here # Wallet private key (use API wallet, not main)

# === Trading config ===
ASSETS="BTC ETH SOL OIL GOLD SILVER SPX"
INTERVAL="5m"
LLM_MODEL="claude-sonnet-4-20250514"             # Claude model to use

# === Risk management (all have sensible defaults) ===
MAX_POSITION_PCT=10                # Max single position as % of portfolio (default: 10)
MAX_LOSS_PER_POSITION_PCT=20       # Force-close at this % loss (default: 20)
MAX_LEVERAGE=10                    # Hard leverage cap (default: 10)
MAX_TOTAL_EXPOSURE_PCT=50          # Max total notional as % of portfolio (default: 50)
DAILY_LOSS_CIRCUIT_BREAKER_PCT=10  # Stop new trades at this daily drawdown % (default: 10)
MANDATORY_SL_PCT=5                 # Auto SL distance % if LLM doesn't set one (default: 5)
MAX_CONCURRENT_POSITIONS=10        # Max simultaneous positions (default: 10)
MIN_BALANCE_RESERVE_PCT=20         # Don't trade below this % of initial balance (default: 20)

# === Optional ===
HYPERLIQUID_NETWORK=mainnet        # mainnet or testnet
# THINKING_ENABLED=false           # Enable Claude extended thinking
# THINKING_BUDGET_TOKENS=10000     # Token budget for thinking
# MAX_TOKENS=4096                  # Max output tokens for Claude
# SANITIZE_MODEL=claude-haiku-4-5-20251001  # Cheap model for output normalization
# API_HOST=0.0.0.0
# API_PORT=3000
